---
import Canvas from "../shared/canvas.astro";
import Goals from "./components/goals.astro";
---

<Goals
  id="non-linear-sequence-goals"
  goals={["Clique em qualquer lugar para visualizar a sequência."]}
/>
<Canvas
  id="non-linear-sequence-canvas"
  label="Percorrendo a Estrutura Não Linear"
  height="504px"
/>
<script>
  import { createArrow } from "./utils/Arrows";
  import {
    createNodeAt,
    createArrowAt,
    createSequenceAnimation,
  } from "./nonLinearSequenceAnim";
  import { markGoalAsComplete } from "./staticMemAnim";
  import { atom } from "nanostores";

  let canvas = document.getElementById(
    "non-linear-sequence-canvas",
  ) as HTMLElement;
  let canvasWidth = canvas.clientWidth;
  let canvasHeight = canvas.clientHeight;

  let nodeLimitPerRow = 4;
  let nodeSize = 90; // node visual size
  nodeSize = Math.min(nodeSize, canvasWidth / 6.5);

  let borderSize = 2;
  let nodeOffsetPerNode = nodeSize + borderSize; // +2 cause of
  // the border

  let arrowWidth = nodeSize / 2;
  console.log(arrowWidth);

  let nodeOffsetLeft =
    (canvasWidth -
      nodeOffsetPerNode * nodeLimitPerRow -
      arrowWidth * (nodeLimitPerRow - 1)) /
    2;
  let nodeOffsetPerRow = arrowWidth;
  let nodeOffsetTop =
    (canvasHeight - 3 * nodeOffsetPerNode - 2 * arrowWidth) / 2;
  if (nodeSize != 90) nodeOffsetTop = 50;
  let nodeOffsetTopFirstRow = nodeOffsetTop;
  let nodeOffsetTopSecondRow =
    nodeOffsetTop + nodeOffsetPerNode + nodeOffsetPerRow;
  let nodeOffsetTopThirdRow =
    nodeOffsetTopSecondRow + nodeOffsetPerNode + nodeOffsetPerRow;
  console.log("NodeOffsetPerNode", nodeOffsetPerNode);
  console.log("NodeOffsetPerRow", nodeOffsetPerRow);
  console.log("First row", nodeOffsetTopFirstRow);
  console.log("Second row", nodeOffsetTopSecondRow);
  console.log("Third row", nodeOffsetTopThirdRow);

  let rowHorizontalSize =
    nodeLimitPerRow * nodeOffsetPerNode + (nodeLimitPerRow - 1) * arrowWidth;

  canvasHeight = 2 * nodeOffsetTop + 3 * nodeOffsetPerNode + 2 * arrowWidth;
  canvas.style.height = `${canvasHeight}px`;

  let sizes = {
    canvasWidth,
    canvasHeight,
    nodeSize,
    nodeOffsetTop,
    nodeOffsetLeft,
    nodeOffsetPerNode,
    nodeOffsetPerRow,
    nodeAmount: 4,
    arrowWidth,
    rowHorizontalSize,
  };

  let nodesClassName = "non-linear-sequence-node-slot";

  let elements = {
    canvas,
    nodes: [] as HTMLElement[],
    arrows: [] as SVGSVGElement[],
  };

  let rootArrow = createArrow({
    id: "non-linear-sequence-root-arrow",
    arrowWidth: sizes.arrowWidth,
    arrowType: "root",
    top: nodeOffsetTopSecondRow,
    left: sizes.nodeOffsetLeft - sizes.arrowWidth - sizes.nodeSize,
    nodeHeight: sizes.nodeSize,
    nodeWidth: sizes.nodeSize,
  });
  elements.arrows.push(rootArrow);
  elements.canvas.appendChild(rootArrow);

  let tags = {
    nodesClassName,
  };

  // create nodes in line from 0 to 3
  sizes.nodeOffsetTop = nodeOffsetTopSecondRow;
  for (let nodeIndex = 0; nodeIndex < sizes.nodeAmount; nodeIndex++) {
    createNodeAt(elements, tags, sizes, nodeIndex, `${nodeIndex}`);
    if (nodeIndex != sizes.nodeAmount - 1) {
      createArrowAt(elements, nodeIndex, tags, sizes, "right", 0.9);
      createArrowAt(elements, nodeIndex, tags, sizes, "left", 0.7);
    }
  }

  // create node 4 and arrows
  sizes.nodeOffsetTop = nodeOffsetTopFirstRow;
  createNodeAt(elements, tags, sizes, 1, "4");

  // create node 4 arrow up
  sizes.nodeOffsetTop = nodeOffsetTopFirstRow;
  createArrowAt(elements, 1, tags, sizes, "up", 0.9);

  // create node 4 arrow down
  sizes.nodeOffsetTop = nodeOffsetTopFirstRow;
  let previousLeft = sizes.nodeOffsetLeft;
  sizes.nodeOffsetLeft = previousLeft - sizes.nodeSize / 2;
  createArrowAt(elements, 1, tags, sizes, "down", 0.9);
  // reset left
  sizes.nodeOffsetLeft = previousLeft;

  // create node 5 and arrows
  sizes.nodeOffsetTop = nodeOffsetTopThirdRow;
  createNodeAt(elements, tags, sizes, 2, "5");
  sizes.nodeOffsetTop = nodeOffsetTopSecondRow;

  // create node 5 arrow down
  createArrowAt(elements, 2, tags, sizes, "down", 0.9);

  // create node 5 arrow up
  sizes.nodeOffsetLeft = previousLeft - sizes.nodeSize / 2;
  createArrowAt(elements, 2, tags, sizes, "up", 0.9);

  let goals = document.getElementById(
    "non-linear-sequence-goals-ul",
  ) as HTMLUListElement;

  const any = atom(false);
  any.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[0] as HTMLLIElement);
  });

  canvas.onclick = async (e: PointerEvent) => {
    if (!any.get()) any.set(true);
    await createSequenceAnimation(elements);
  };
</script>
