---
import Canvas from "../shared/canvas.astro";
import Goals from "./components/goals.astro";
---

<Goals
  id="dynamic-memory-goals"
  goals={[
    "Clique em um espaço para adicionar um valor.",
    "Clique entre dois blocos para criar um novo bloco entre eles.",
    "Clique antes do primeiro bloco para criar um novo bloco no ínicio",
    "Clique e adicione ao menos 5 blocos.",
    "Clique em um bloco para removê-lo.",
    "Clique em um bloco entre dois blocos para removê-lo.",
    "Clique no primeiro bloco para removê-lo.",
    "Clique no último bloco para removê-lo.",
    "Clique e remove todos os blocos.",
  ]}
/>
<Canvas id="dynamic-memory-canvas" label="Dinâmico" height="300px" />
<script>
  import {
    currentNodeValue,
    totalNodes,
    cursorPosition,
    animationBlock,
    any,
    between,
    atStart,
    atLeastFive,
    anyRemoved,
    betweenRemoved,
    atStartRemoved,
    atEndRemoved,
    removedAll,
  } from "./stores/dynamic-memory.store";
  import {
    createNodeAt,
    calculateClickActionByEvent,
    calculateNodeIndexByEvent,
    calculateNodeIndexByNodePosition,
    removeNodeAt,
    moveBackward,
    createArrowAtEnd,
    expandCanvasIfNeeded,
    shrinkCanvasIfNeeded,
    removeArrowAtEnd,
    moveForward,
  } from "./dynamicMemAnim";
  import { createArrow } from "./utils/Arrows";
  import { setupEngine } from "../engine.default";
  import { markGoalAsComplete } from "./staticMemAnim";

  setupEngine();

  let canvas = document.getElementById("dynamic-memory-canvas") as HTMLElement;
  let canvasWidth = canvas.clientWidth;
  let canvasHeight = canvas.clientHeight;

  let arrowWidth = 56;
  let nodeLimitPerRow = 4;
  let nodeSize = 90; // node visual size
  // if (nodeSize * nodeLimitPerRow + arrowWidth * (nodeLimitPerRow - 1) > canvasWidth)
  //   nodeSize = canvasWidth / (nodeLimitPerRow + 0.5);

  let borderSize = 2;
  let nodeOffsetPerNode = nodeSize + borderSize; // +2 cause of the border
  let nodeOffsetLeft =
    (canvasWidth -
      nodeOffsetPerNode * nodeLimitPerRow -
      arrowWidth * (nodeLimitPerRow - 1)) /
    2;
  let nodeOffsetTop = 74;
  let nodeOffsetRow = 30;
  let rowSize =
    nodeLimitPerRow * nodeOffsetPerNode + (nodeLimitPerRow - 1) * arrowWidth;

  let sizes = {
    canvasWidth,
    canvasHeight,
    nodeSize,
    nodeLimitPerRow,
    nodeOffsetTop,
    nodeOffsetPerNode,
    nodeOffsetLeft,
    nodeOffsetRow,
    nodeAmount: 0,
    arrowWidth,
    rowSize,
  };

  let nodesClassName = "dynamic-mem-node-slot";

  let elements = {
    canvas,
    nodes: [] as HTMLElement[],
    arrows: [] as SVGSVGElement[],
  };

  let rootArrow = createArrow({
    id: "dynamic-mem-root-arrow",
    arrowWidth: sizes.arrowWidth,
    arrowType: "root",
    top: sizes.nodeOffsetTop,
    left: sizes.nodeOffsetLeft - sizes.arrowWidth - sizes.nodeSize,
    nodeHeight: sizes.nodeSize,
    nodeWidth: sizes.nodeSize,
  });
  elements.arrows.push(rootArrow);
  elements.canvas.appendChild(rootArrow);

  let tags = {
    nodesClassName,
  };

  const increaseStores = () => {
    currentNodeValue.set(currentNodeValue.get() + 1);
    totalNodes.set(totalNodes.get() + 1);
    sizes.nodeAmount = totalNodes.get();
  };

  const decreaseStores = () => {
    totalNodes.set(totalNodes.get() - 1);
    sizes.nodeAmount = totalNodes.get();
  };

  const logStores = () => {
    console.log("Current Node Value: ", currentNodeValue.get());
    console.log("Total Nodes: ", totalNodes.get());
    console.log("Nodes Amount: ", sizes.nodeAmount);
  };

  let goals = document.getElementById(
    "dynamic-memory-goals-ul",
  ) as HTMLUListElement;

  any.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[0] as HTMLLIElement);
  });

  between.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[1] as HTMLLIElement);
  });

  atStart.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[2] as HTMLLIElement);
  });

  atLeastFive.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[3] as HTMLLIElement);
  });

  anyRemoved.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[4] as HTMLLIElement);
  });

  betweenRemoved.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[5] as HTMLLIElement);
  });

  atStartRemoved.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[6] as HTMLLIElement);
  });

  atEndRemoved.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[7] as HTMLLIElement);
  });

  removedAll.subscribe((value) => {
    if (!value) return;
    markGoalAsComplete(goals.childNodes[8] as HTMLLIElement);
  });

  canvas.onclick = async (e: PointerEvent) => {
    if (animationBlock.get()) return;
    animationBlock.set(true);
    canvas.style.cursor = "wait";

    let clickAction = calculateClickActionByEvent(e);
    if (clickAction == "insert") {
      // Insert Action
      // Every Insert Action requires a node and a arrow to be created.
      // The position of the node to be insert should be calculated.
      // The arrow to be inserted will alyways be the last one.
      if (!any.get()) any.set(true);

      await expandCanvasIfNeeded(elements, sizes);

      let nodeIndex = calculateNodeIndexByEvent(e, sizes, elements);
      let currentValue = currentNodeValue.get();
      let totalNodesValue = totalNodes.get();
      sizes.nodeAmount = totalNodesValue;

      if (
        !between.get() &&
        sizes.nodeAmount >= 2 &&
        nodeIndex != 0 &&
        nodeIndex != totalNodesValue
      )
        between.set(true);

      if (!atStart.get() && nodeIndex == 0 && totalNodesValue > 0)
        atStart.set(true);

      if (!atLeastFive.get() && currentValue >= 4) atLeastFive.set(true);

      if (sizes.nodeAmount != 0) createArrowAtEnd(elements, tags, sizes);

      let positionToPush = sizes.nodeAmount - 1;
      while (positionToPush >= nodeIndex) {
        await moveForward(
          elements.nodes[positionToPush],
          positionToPush + 1,
          sizes,
        );
        positionToPush--;
      }

      createNodeAt(elements, tags, sizes, nodeIndex, currentValue);

      increaseStores();
    } else if (clickAction == "remove") {
      // Remove Action
      // Every Remove Action requires a node and a arrow to be removed.
      // The position of the node to be removed should be calculated.
      // The arrow to be removed will always be the last one.

      let nodeIndex = calculateNodeIndexByNodePosition(
        e.target as HTMLElement,
        elements,
      );
      removeNodeAt(elements, nodeIndex);

      if (!anyRemoved.get()) anyRemoved.set(true);

      if (
        !betweenRemoved.get() &&
        nodeIndex != 0 &&
        nodeIndex != elements.nodes.length
      )
        betweenRemoved.set(true);

      if (!atStartRemoved.get() && nodeIndex == 0) atStartRemoved.set(true);

      if (!atEndRemoved.get() && nodeIndex == elements.nodes.length)
        atEndRemoved.set(true);

      if (!removedAll.get() && elements.nodes.length == 0) removedAll.set(true);

      let positionToPull = nodeIndex;
      while (positionToPull < sizes.nodeAmount - 1) {
        await moveBackward(
          elements.nodes[positionToPull],
          positionToPull,
          sizes,
        );
        positionToPull++;
      }

      removeArrowAtEnd(elements);

      decreaseStores();

      await shrinkCanvasIfNeeded(elements, sizes);
    }

    canvas.style.cursor = "pointer";
    animationBlock.set(false);
  };
</script>
